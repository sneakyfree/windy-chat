# windy-chat ops-hook — systemd unit env (install to /etc/windy-chat-ops-hook.env, 0600).
# Chat is a MULTI-SERVICE constellation, so the star knob here is per-service
# restart (reconnect.<service>): the aggregator (GET /api/v1/ops/health) shows
# which service is down, this restarts just that one. Facts from the chat
# host (EC2 i-0f603361b88baa4c0, 3.239.252.15 — Chat's OWN box).
#
# ⚠️ Verify OPS_HOOK_IMAGE_REF on the host if you enable single-service
# redeploy (each Chat service builds its own :local image):
#     cd /opt/windy-chat && docker compose -p windy-chat -f docker-compose.yml \
#         -f docker-compose.prod.yml --env-file .env.production images

OPS_HOOK_TOKEN=CHANGME_openssl_rand_base64_33
OPS_HOOK_PRODUCT=windy-chat
OPS_HOOK_WORKDIR=/opt/windy-chat
# BOTH overlay files + env-file are required or compose fails on missing vars.
OPS_HOOK_COMPOSE_CMD=docker compose -p windy-chat -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production

# ── The per-service reconnect allowlist (the Chat knob) ──
# The Node microservices + bridges. DELIBERATELY EXCLUDES: synapse (the P0
# Matrix kernel — NEVER bounce it; standing rule), synapse-db, synapse-redis,
# coturn (datastores/TURN), nginx (host-managed), web (off-host SPA).
OPS_HOOK_SERVICES=onboarding,directory,push-gateway,backup,social,translation,agent-roster,hub,bridge-telegram,bridge-slack,bridge-whatsapp,bridge-discord,media,call-history

# Single-service target for /hook/restart + the health-gate = onboarding
# (host-bound at 127.0.0.1:8101; also hosts the aggregator).
OPS_HOOK_SERVICE=onboarding
OPS_HOOK_PATIENT_URL=http://127.0.0.1:8101
# Redeploy/config are not Chat's primary use (multi-service, per-service
# images) — leave IMAGE_REF + CONFIG_ALLOWLIST unset (those knobs report
# disabled/verify-on-host). restart-service is the value here.
# OPS_HOOK_IMAGE_REF=
# OPS_HOOK_CONFIG_ALLOWLIST=

# Chat is on its own box → 8901 is free.
OPS_HOOK_BIND=127.0.0.1
OPS_HOOK_PORT=8901
