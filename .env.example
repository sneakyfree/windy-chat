# ── Windy Chat Backend Configuration ──

# Synapse (Matrix Homeserver)
SYNAPSE_SERVER_NAME=chat.windypro.com
SYNAPSE_DB_PASSWORD=change_me_in_production
SYNAPSE_REGISTRATION_SECRET=change_me_in_production
SYNAPSE_ADMIN_TOKEN=

# TURN Server (VoIP NAT traversal)
TURN_SHARED_SECRET=change_me_in_production

# Windy Pro Account Server (identity authority)
WINDY_ACCOUNT_SERVER_URL=http://localhost:8098
WINDY_JWT_SECRET=must_match_account_server_jwt_secret

# Onboarding Service (K2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@windychat.com
OTP_EXPIRY_MINUTES=10

# Directory Service (K3)
DIRECTORY_PORT=8102

# Push Gateway (K6)
PUSH_GATEWAY_PORT=8103
FCM_SERVICE_ACCOUNT_PATH=
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=

# Backup Service (K8)
BACKUP_PORT=8104
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=windy-chat-backups
R2_ENDPOINT=

# Redis
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
