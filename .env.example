# ──────────────────────────────────────────────────────────────────────
# Windy Chat Backend — Configuration
# ──────────────────────────────────────────────────────────────────────
# Every variable read by any service in services/**/server.js or
# services/**/routes/**.js should have an entry here with a safe dev
# default (or left blank + documented). Missing entries were flagged by
# the Wave-7 gap analysis (P1-9 / P1-10).
#
# Runtime mode
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────
# Synapse (Matrix homeserver) — K1
# ──────────────────────────────────────────────────────────────────────
SYNAPSE_SERVER_NAME=chat.windychat.ai
SYNAPSE_URL=http://localhost:8008
# Override only if your Synapse admin API lives somewhere else — defaults
# to ${SYNAPSE_URL}/_synapse/admin.
SYNAPSE_ADMIN_URL=
SYNAPSE_ADMIN_TOKEN=
SYNAPSE_DB_PASSWORD=change_me_in_production
SYNAPSE_REGISTRATION_SECRET=change_me_in_production

# ──────────────────────────────────────────────────────────────────────
# TURN Server (VoIP NAT traversal)
# ──────────────────────────────────────────────────────────────────────
TURN_SHARED_SECRET=change_me_in_production

# ──────────────────────────────────────────────────────────────────────
# Windy Pro Account Server (identity authority)
# ──────────────────────────────────────────────────────────────────────
WINDY_ACCOUNT_SERVER_URL=http://localhost:8098
WINDY_JWT_SECRET=must_match_account_server_jwt_secret

# ──────────────────────────────────────────────────────────────────────
# Service-to-service auth
# ──────────────────────────────────────────────────────────────────────
# Legacy static bearer — any service-to-service call accepts this. Retire
# once all callers migrate to proper JWT. CHAT_SERVICE_TOKEN is preferred
# for new callers.
CHAT_API_TOKEN=
CHAT_SERVICE_TOKEN=
# Shared secret for the cross-service push bus (push-gateway :8103).
# Callers: Synapse windy_push_bus module, Mail/Clone/Fly/Code.
PUSH_BUS_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Onboarding Service (K2) — :8101
# ──────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@windychat.ai
OTP_EXPIRY_MINUTES=10
# HMAC secret for the POST /api/v1/webhooks/identity/created endpoint
# (used by the Windy Pro account-server to eagerly provision chat users).
WINDY_IDENTITY_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Directory Service (K3) — :8102
# ──────────────────────────────────────────────────────────────────────
DIRECTORY_PORT=8102

# ──────────────────────────────────────────────────────────────────────
# Push Gateway (K6) — :8103
# ──────────────────────────────────────────────────────────────────────
PUSH_GATEWAY_PORT=8103
# FCM — path to the Firebase service-account JSON file. Note this is the
# variable name the code actually reads (NOT FCM_SERVICE_ACCOUNT_PATH).
FIREBASE_SERVICE_ACCOUNT=
# APNs
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.windypro.chat
# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@windychat.ai

# ──────────────────────────────────────────────────────────────────────
# Media Service (K4) — :8107
# ──────────────────────────────────────────────────────────────────────
MEDIA_STORAGE_PATH=

# ──────────────────────────────────────────────────────────────────────
# Backup Service (K8) — :8104
# ──────────────────────────────────────────────────────────────────────
BACKUP_PORT=8104
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=windy-chat-backups
R2_ENDPOINT=
# Windy Cloud (backup routing fallback)
WINDY_CLOUD_URL=http://localhost:8200

# ──────────────────────────────────────────────────────────────────────
# Translation (K9) — :8106
# ──────────────────────────────────────────────────────────────────────
WINDY_TRANSLATE_URL=http://localhost:9877
# Matrix appservice tokens (Synapse ↔ translation bridge)
TRANSLATION_AS_TOKEN=
TRANSLATION_HS_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Call History (K5) — :8108
# ──────────────────────────────────────────────────────────────────────
CALL_HISTORY_AS_TOKEN=
CALL_HISTORY_HS_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Eternitas (bot passport registry + Trust API + webhooks)
# ──────────────────────────────────────────────────────────────────────
# Single canonical URL — every service reads ETERNITAS_URL. ETERNITAS_API_URL
# is accepted as a fallback for pre-Wave-4 callers. Dev default points
# at the local Eternitas dev instance.
ETERNITAS_URL=http://localhost:8500
# Returns deterministic mock profiles without hitting the network. ONLY
# for tests + local dev before Eternitas is up. MUST be false in prod.
ETERNITAS_USE_MOCK=false
# HMAC secret Eternitas signs passport.* webhooks with. Must match the
# platform's webhook_secret set at platform registration.
ETERNITAS_WEBHOOK_SECRET=
# Where Eternitas should POST passport lifecycle webhooks. Must resolve
# to social's /api/v1/webhooks/eternitas handler.
ETERNITAS_WEBHOOK_URL=https://chat.windychat.ai/api/v1/webhooks/eternitas

# ──────────────────────────────────────────────────────────────────────
# CORS — additional origins (comma-separated)
# ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=

# ──────────────────────────────────────────────────────────────────────
# Redis (shared OTP / trust cache / pairing sessions)
# ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────
# Sentry (optional error reporting)
# ──────────────────────────────────────────────────────────────────────
SENTRY_DSN=
