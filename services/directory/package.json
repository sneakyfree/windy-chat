{
  "name": "windy-chat-directory",
  "version": "1.0.0",
  "description": "Windy Chat — K3 Contact Discovery service (hash lookup, search, invite)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --forceExit --detectOpenHandles && node --test tests/trust-gates.test.js tests/gate-tier-scaling.test.js",
    "test:jest": "jest --forceExit --detectOpenHandles",
    "test:integration": "node --test tests/trust-gates.test.js tests/gate-tier-scaling.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.0",
    "uuid": "^9.0.0"
  },
  "private": true,
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^jwks-rsa$": "<rootDir>/../shared/__mocks__/jwks-rsa.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/trust-gates.test.js",
      "/tests/gate-tier-scaling.test.js"
    ]
  }
}
