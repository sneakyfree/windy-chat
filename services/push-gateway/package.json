{
  "name": "windy-chat-push-gateway",
  "version": "1.0.0",
  "description": "Windy Chat — K6 Push notification gateway (Matrix → FCM/APNs)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --forceExit --detectOpenHandles && node --test tests/fcm-channels.test.js",
    "test:jest": "jest --forceExit --detectOpenHandles",
    "test:integration": "node --test tests/fcm-channels.test.js"
  },
  "dependencies": {
    "apn": "^2.2.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7"
  },
  "private": true,
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^jwks-rsa$": "<rootDir>/../shared/__mocks__/jwks-rsa.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/fcm-channels.test.js"
    ]
  }
}
