node_modules/
.env
.env.production
.env.production.*
*.log
dist/
.DS_Store
deploy/synapse/data/
deploy/synapse/certs/
deploy/certs/
deploy/acme-challenge/
deploy/synapse/*.signing.key

# SQLite databases (persistent data)
services/*/data/*.db
services/*/data/*.db-wal
services/*/data/*.db-shm

# Media uploads
services/media/data/media/
services/onboarding/data/avatars/

# Auto-generated secrets (dev mode)
services/.env.generated

# Firebase / APNs credentials
*.p8
*-firebase-adminsdk-*.json

# Eternitas platform registration
services/.eternitas-platform-id

# DB backups
backups/

# Hand-made operational backups created on EC2 hosts (e.g.
# docker-compose.prod.yml.bak.2026-05-17, .pre-volume-mount-2026-05-17).
# Per ADR-048, every meaningful host-side change should be captured in
# deploy/SUBSTRATE.md "Audit history" instead of leaving .bak files
# scattered on the host. Gitignore prevents them from being staged
# back into the repo on a future sync. (Audit surfaced 2026-05-17.)
*.bak.*
*.pre-*
