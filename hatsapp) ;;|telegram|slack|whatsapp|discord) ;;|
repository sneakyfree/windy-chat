# Windy Chat — Enable a Hub Mode bridge (slack | slack | whatsapp).
#   sudo bash scripts/enable-hub-bridge.sh slack
#   slack only: TELEGRAM_API_ID / TELEGRAM_API_HASH (my.telegram.org)
  slack|slack|whatsapp) ;;
  *) echo "usage: $0 slack|slack|whatsapp" >&2; exit 1 ;;
[ "$NETWORK" = slack ] && REQUIRED+=(TELEGRAM_API_ID TELEGRAM_API_HASH)
    "$ROOT_DIR/services/bridges/slack/doublepuppet-registration.yaml.template" \
