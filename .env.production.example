# ──────────────────────────────────────────────────────────────────────
# Windy Chat Backend — Production Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy to `.env.production` on the VPS and fill in every REPLACE_ME.
# Every secret should come from `openssl rand -hex 32` unless noted.
# See DEPLOY.md for provisioning steps and context.
#
# DO NOT commit the populated version. `.env.production` is in .gitignore.

NODE_ENV=production

# ──────────────────────────────────────────────────────────────────────
# Synapse (Matrix homeserver) — K1
# ──────────────────────────────────────────────────────────────────────
SYNAPSE_SERVER_NAME=chat.windychat.ai
SYNAPSE_URL=http://synapse:8008
SYNAPSE_ADMIN_URL=http://synapse:8008/_synapse/admin
# Long-lived admin access token minted once via `register_new_matrix_user
# --admin`. Used by onboarding/backup for privileged operations.
SYNAPSE_ADMIN_TOKEN=REPLACE_ME_SYNAPSE_ADMIN_ACCESS_TOKEN

# Synapse Postgres password — matches the docker-compose synapse-db
# service's POSTGRES_PASSWORD.
SYNAPSE_DB_PASSWORD=REPLACE_ME_SYNAPSE_DB_PASSWORD

# Shared-secret HMAC used by account-server to register Matrix users
# against Synapse's admin API. Must also match the value in
# homeserver.yaml (`registration_shared_secret`).
SYNAPSE_REGISTRATION_SECRET=REPLACE_ME_HEX_32

# Signs Synapse macaroons (login/reset tokens). Rotating invalidates
# every active session — only do so during a planned maintenance.
SYNAPSE_MACAROON_SECRET_KEY=REPLACE_ME_HEX_32

# Signs forms rendered by Synapse (registration, password reset).
SYNAPSE_FORM_SECRET=REPLACE_ME_HEX_32

# ──────────────────────────────────────────────────────────────────────
# PostgreSQL (Synapse DB) / Redis (OTP + streams)
# ──────────────────────────────────────────────────────────────────────
# Consumed by Node services that need direct access; Synapse reads its
# own config from homeserver.yaml.
DATABASE_URL=postgres://synapse:${SYNAPSE_DB_PASSWORD}@synapse-db:5432/synapse
REDIS_URL=redis://synapse-redis:6379

# ──────────────────────────────────────────────────────────────────────
# TURN Server (Coturn) — VoIP NAT traversal
# ──────────────────────────────────────────────────────────────────────
# Generate with `openssl rand -hex 32`. Same value goes into
# turnserver.conf (`static-auth-secret`) and Synapse
# (`turn_shared_secret`).
COTURN_SHARED_SECRET=REPLACE_ME_HEX_32
TURN_SHARED_SECRET=${COTURN_SHARED_SECRET}
TURN_URIS=turn:chat.windychat.ai:3478?transport=udp,turn:chat.windychat.ai:3478?transport=tcp,turns:chat.windychat.ai:5349?transport=tcp

# Coturn realm (Wave 14) — sent in auth challenges; conventionally
# matches the public hostname. Defaults to chat.windychat.ai.
COTURN_REALM=chat.windychat.ai

# Coturn external-ip (Wave 14) — the public EIP coturn advertises to
# clients for reflexive/relay candidates. For EC2 behind a 1:1 NAT
# (i.e. an Elastic IP), use the `PUBLIC_IP/PRIVATE_IP` syntax so coturn
# composes candidates on both sides of the NAT. Example:
#
#   COTURN_EXTERNAL_IP=3.239.252.15/10.20.1.247
#
# Rotate this whenever the EIP changes (today that's auto-assigned;
# swap to an allocated EIP once Grant's quota request lands — the
# allocated EIP's private mapping comes from `ip addr` on the box).
COTURN_EXTERNAL_IP=REPLACE_ME_PUBLIC_IP/PRIVATE_IP

# ──────────────────────────────────────────────────────────────────────
# Windy Pro — identity authority
# ──────────────────────────────────────────────────────────────────────
WINDY_ACCOUNT_SERVER_URL=https://account.windyword.ai
# JWKS endpoint — Chat validates every client JWT against this URL's
# RSA public keys. Pro rotates daily; cache is 10 min.
WINDY_JWKS_URL=https://account.windyword.ai/.well-known/jwks.json
# HS256 fallback (only used for internally-signed service tokens; Pro's
# client tokens are RS256 via JWKS).
WINDY_JWT_SECRET=REPLACE_ME_MUST_MATCH_PRO_SERVICE_SIGNING_KEY

# ──────────────────────────────────────────────────────────────────────
# Service-to-service auth
# ──────────────────────────────────────────────────────────────────────
# Legacy static bearer (retiring). Prefer CHAT_SERVICE_TOKEN for new
# callers; keep CHAT_API_TOKEN populated until every producer migrates.
CHAT_API_TOKEN=REPLACE_ME_HEX_32
CHAT_SERVICE_TOKEN=REPLACE_ME_HEX_32

# Shared bus token — every producer (Mail/Clone/Fly/Code/Chat) presents
# this in `X-Push-Bus-Token` when publishing to push-gateway:8103.
PUSH_BUS_TOKEN=REPLACE_ME_HEX_32

# ──────────────────────────────────────────────────────────────────────
# Onboarding Service (K2) — :8101
# ──────────────────────────────────────────────────────────────────────
# OTP providers — Twilio for SMS, SendGrid for email. Both optional in
# production but at least one is required for phone/email verification.
TWILIO_ACCOUNT_SID=REPLACE_ME_TWILIO_SID
TWILIO_AUTH_TOKEN=REPLACE_ME_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+15551234567
SENDGRID_API_KEY=REPLACE_ME_SG_API_KEY
SENDGRID_FROM_EMAIL=noreply@windychat.ai
OTP_EXPIRY_MINUTES=10

# HMAC secret for POST /api/v1/webhooks/identity/created (the push-side
# onboarding contract Pro uses to eagerly provision Chat users). Must
# equal the value the account-server signs webhooks with.
WINDY_IDENTITY_WEBHOOK_SECRET=REPLACE_ME_HEX_32

# ──────────────────────────────────────────────────────────────────────
# Eternitas (passport / trust)
# ──────────────────────────────────────────────────────────────────────
ETERNITAS_URL=https://api.eternitas.ai
# HMAC secret for the passport.revoked / trust.changed webhooks.
ETERNITAS_WEBHOOK_SECRET=REPLACE_ME_HEX_32

# ──────────────────────────────────────────────────────────────────────
# Push Gateway (K6) — :8103 — FCM / APNs / WebPush
# ──────────────────────────────────────────────────────────────────────
# FCM (Android) — path to the service account JSON, mounted read-only
# into the push-gateway container at /secrets/firebase.json.
FIREBASE_SERVICE_ACCOUNT=/secrets/firebase.json

# APNs (iOS)
APNS_KEY_PATH=/secrets/apns.p8
APNS_KEY_ID=REPLACE_ME_10_CHAR_KEY_ID
APNS_TEAM_ID=REPLACE_ME_10_CHAR_TEAM_ID
APNS_BUNDLE_ID=com.windypro.chat

# WebPush (VAPID)
VAPID_PUBLIC_KEY=REPLACE_ME_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_ME_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:ops@windychat.ai

# ──────────────────────────────────────────────────────────────────────
# Observability (Sentry — optional, recommended in prod)
# ──────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ──────────────────────────────────────────────────────────────────────
# Cloudflare R2 (Backup service cold storage)
# ──────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=REPLACE_ME_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_ME_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=REPLACE_ME_R2_SECRET_KEY
R2_BUCKET=windy-chat-backup-prod

# ──────────────────────────────────────────────────────────────────────
# Smoke test (consumed by scripts/smoke-test.sh)
# ──────────────────────────────────────────────────────────────────────
SMOKE_TEST_WINDY_IDENTITY_ID=smoke_test_id_windy_chat

# ──────────────────────────────────────────────────────────────────────
# Hub Mode (hub :8109 + mautrix bridges) — exec-guide-hub-mode-2026-07-06
# ──────────────────────────────────────────────────────────────────────
# Telegram MTProto app credentials — Grant creates at my.telegram.org
# ("API development tools"); NOT the same thing as a bot token.
TELEGRAM_API_ID=REPLACE_ME_NUMERIC
TELEGRAM_API_HASH=REPLACE_ME_HEX_32
# Bridge provisioning API auth (hub → bridge). openssl rand -hex 32.
HUB_BRIDGE_TELEGRAM_URL=http://bridge-telegram:29317
HUB_BRIDGE_TELEGRAM_PROVISIONING_SECRET=REPLACE_ME_HEX_32
# Double-puppeting appservice tokens (shared by ALL hub bridges).
DOUBLEPUPPET_AS_TOKEN=REPLACE_ME_HEX_32
DOUBLEPUPPET_HS_TOKEN=REPLACE_ME_HEX_32
# Bridge admin (gets mautrix admin commands). Defaults to Grant's MXID.
HUB_ADMIN_MXID=@grant.whitmer:chat.windychat.ai
# Slack + WhatsApp bridges (no app credentials needed — per-user logins).
HUB_BRIDGE_SLACK_URL=http://bridge-slack:29317
HUB_BRIDGE_SLACK_PROVISIONING_SECRET=REPLACE_ME_HEX_32
HUB_BRIDGE_WHATSAPP_URL=http://bridge-whatsapp:29317
HUB_BRIDGE_WHATSAPP_PROVISIONING_SECRET=REPLACE_ME_HEX_32
